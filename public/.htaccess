# Fallback for Apache-backed hosts (Timeweb static often uses nginx — see scripts/spa-fallback.mjs).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{HTTP_HOST} ^(www\.)?pishalking\.biz$ [NC]
  RewriteRule ^ https://pishalking.ru%{REQUEST_URI} [R=301,L]
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
